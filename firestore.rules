rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requester is the user themselves or one of their managers.
    // managers[] is a CF-maintained array of Firebase Auth UIDs up the chain.
    function canAccessUser(userId) {
      let user = get(/databases/$(database)/documents/Users/$(userId));
      return isSignedIn() && (
        request.auth.uid == user.data.uid ||
        request.auth.uid in user.data.get('managers', [])
      );
    }

    // ─── Codes — public read (needed before login), owner-only write ─────────
    match /Codes/{code} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /Users/{userId} {
      // Create: doc doesn't exist yet — only the user themselves may create
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      // Read / update / delete: self or any manager in the chain
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        request.auth.uid in resource.data.get('managers', [])
      );

      match /Tracking/{trackingId} {
        allow read, write: if canAccessUser(userId);
      }

      match /Visits/{visitId} {
        allow read, write: if canAccessUser(userId);

        match /Comments/{commentId} {
          allow read: if canAccessUser(userId);
          allow create: if isSignedIn() &&
            request.resource.data.userId is string &&
            request.resource.data.text is string &&
            request.resource.data.timestamp is timestamp;
        }
      }

      match /Monthly/{yearMonth} {
        allow read, write: if canAccessUser(userId);
      }
    }
  }
}