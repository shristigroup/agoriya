rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requester is the user themselves or one of their managers.
    // managers[] is a CF-maintained array of User doc IDs up the chain.
    function canAccessUser(userId) {
      let user = get(/databases/$(database)/documents/Users/$(userId));
      return isSignedIn() && (
        request.auth.token.userId == userId ||
        request.auth.token.userId in user.data.get('managers', [])
      );
    }

    // ─── Codes — public read, owner-only create; update/delete via CF only ──
    match /Codes/{code} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.token.userId;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /Users/{userId} {
      // Create: custom claim not set yet at first creation — verify via auth.uid
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      // Read / update / delete: self or any manager in the chain
      allow read, update, delete: if isSignedIn() && (
        request.auth.token.userId == userId ||
        request.auth.token.userId in resource.data.get('managers', [])
      );

      match /Tracking/{trackingId} {
        allow read, write: if canAccessUser(userId);
      }

      match /Visits/{visitId} {
        allow read, write: if canAccessUser(userId);

        match /Comments/{commentId} {
          allow read: if canAccessUser(userId);
          allow create: if canAccessUser(userId) &&
            request.resource.data.userId == request.auth.token.userId &&
            request.resource.data.text is string &&
            request.resource.data.timestamp is timestamp;
        }
      }

      match /Monthly/{yearMonth} {
        allow read, write: if canAccessUser(userId);
      }
    }
  }
}